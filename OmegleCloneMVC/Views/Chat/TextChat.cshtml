@{
    ViewData["Title"] = "Text Chat";
}

<div class="text-chat-wrapper">
    <div class="tc-topbar">
        <div class="tc-status" id="tcStatus">Klikni Start da počneš</div>
        <button id="reportBtn" type="button" class="tc-ghost-btn" onclick="openReportModal()" disabled>🚩 Prijavi</button>
    </div>

    <div class="tc-chat-area">
        <div id="loader" class="tc-loader" style="display:none;">
            <div class="tc-spinner"></div>
            <div class="tc-loader-text">Tražimo partnera...</div>
        </div>

        <div id="textChatBox"></div>
        <div id="typingStatus"></div>
    </div>

    <div class="input-row">
        <input type="text" id="interestInput" placeholder="Interesovanja (opciono): sport, film, muzika..." />
        <button id="startBtn" type="button" class="tc-primary-btn" onclick="startOrNextTextChat()">Start</button>
    </div>

    <div class="input-row">
        <input type="text" id="textMessageInput" placeholder="Napiši poruku..." oninput="notifyTextTyping()" />
        <button type="button" class="tc-primary-btn" onclick="sendTextMessage()">Send</button>
    </div>

    <small class="tc-esc-text">(ESC za sledećeg partnera)</small>
</div>

<div id="reportModal" class="modal-overlay" style="display:none;">
    <div class="modal-content">
        <div class="modal-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" /><line x1="4" y1="22" x2="4" y2="2" /></svg>
        </div>
        <h2>Prijavi ovog korisnika</h2>
        <p>Razgovor će se odmah prekinuti i potražićemo ti novog partnera.</p>
        <select id="reportReason" class="report-reason-select">
            <option value="inappropriate">Neprimereno ponašanje</option>
            <option value="nudity">Nagost / seksualni sadržaj</option>
            <option value="harassment">Uznemiravanje / vređanje</option>
            <option value="underage">Maloletna osoba</option>
            <option value="spam">Spam / reklamiranje</option>
            <option value="other">Drugo</option>
        </select>
        <div class="modal-buttons">
            <button onclick="submitTextReport()">Prijavi i dalje</button>
            <button class="modal-cancel-btn" onclick="closeReportModal()">Otkaži</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let chatConnection = null;
        let typingTimeout = null;
        let hasStarted = false;
        let lastNextMs = 0;
        const NEXT_DEBOUNCE_MS = 1500;

        function setStatus(text) {
            const el = document.getElementById("tcStatus");
            if (el) el.textContent = text;
        }

        function showLoader(show) {
            const el = document.getElementById("loader");
            if (el) el.style.display = show ? "flex" : "none";
        }

        function setMainButton(started) {
            hasStarted = started;
            const btn = document.getElementById("startBtn");
            if (btn) btn.textContent = started ? "Next" : "Start";
        }

        function setReportEnabled(enabled) {
            const btn = document.getElementById("reportBtn");
            if (btn) btn.disabled = !enabled;
        }

        function appendTextChat(text, type = "system") {
            const box = document.getElementById("textChatBox");
            const div = document.createElement("div");
            div.className = "tc-msg " + type;
            div.textContent = text;
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        async function startOrNextTextChat() {
            if (!hasStarted) { await startTextChat(); return; }
            await nextTextPartner();
        }

        async function startTextChat() {
            if (chatConnection && chatConnection.state === "Connected") return;

            const interestInput = document.getElementById("interestInput");
            const interest = interestInput.value.trim();

            showLoader(true);
            setStatus("Tražimo partnera...");
            interestInput.disabled = true;

            chatConnection = new signalR.HubConnectionBuilder()
                .withUrl("/textChatHub?interest=" + encodeURIComponent(interest))
                .withAutomaticReconnect()
                .build();

            chatConnection.on("ReceiveMessage", msg => {
                const isSystem = msg.startsWith("✅") || msg.startsWith("❌");
                appendTextChat(msg, isSystem ? "system" : "partner");
                if (msg.startsWith("✅")) {
                    showLoader(false);
                    setStatus("Povezan/a sa partnerom");
                    setReportEnabled(true);
                }
            });

            chatConnection.on("ReceiveTyping", () => {
                const ts = document.getElementById("typingStatus");
                if (!ts) return;
                ts.innerHTML = `Partner kuca <span class="typing-dots"><span></span><span></span><span></span></span>`;
                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(() => ts.innerHTML = "", 1500);
            });

            chatConnection.on("PartnerDisconnected", () => {
                appendTextChat("❌ Partner je napustio chat.", "system");
                setReportEnabled(false);
                showLoader(true);
                setStatus("Tražimo novog partnera...");
                const ts = document.getElementById("typingStatus");
                if (ts) ts.innerHTML = "";
            });

            chatConnection.on("Banned", () => {
                appendTextChat("🚫 Privremeno si ograničen zbog više prijava. Pokušaj kasnije.", "system");
                showLoader(false);
                setStatus("Ograničen");
                setReportEnabled(false);
                chatConnection.stop();
            });

            chatConnection.onreconnected(() => {
                appendTextChat("✅ Ponovo povezano.", "system");
            });

            chatConnection.onclose(() => {
                setMainButton(false);
                setReportEnabled(false);
                showLoader(false);
                setStatus("Konekcija zatvorena. Klikni Start.");
                interestInput.disabled = false;
            });

            try {
                await chatConnection.start();
            } catch (e) {
                appendTextChat("❌ Connection failed. Please refresh the page.", "system");
                showLoader(false);
                setStatus("Greška. Klikni Start.");
                interestInput.disabled = false;
                return;
            }

            setMainButton(true);
            appendTextChat("🔎 Tražimo partnera...", "system");
        }

        function sendTextMessage() {
            const msgInput = document.getElementById("textMessageInput");
            const msg = msgInput.value.trim();
            if (!msg) return;

            if (!chatConnection || chatConnection.state !== "Connected") {
                appendTextChat("⚠️ Nisi povezan. Klikni Start.", "system");
                return;
            }

            appendTextChat(msg, "me");
            chatConnection.invoke("SendMessage", msg);
            msgInput.value = "";
            msgInput.focus();
        }

        function notifyTextTyping() {
            if (chatConnection && chatConnection.state === "Connected") {
                chatConnection.invoke("SendTyping");
            }
        }

        async function nextTextPartner() {
            if (!chatConnection || chatConnection.state !== "Connected") {
                appendTextChat("⚠️ Nisi povezan. Klikni Start.", "system");
                return;
            }

            const now = Date.now();
            if (now - lastNextMs < NEXT_DEBOUNCE_MS) return;
            lastNextMs = now;

            document.getElementById("typingStatus").innerHTML = "";
            document.getElementById("textMessageInput").value = "";
            showLoader(true);
            setStatus("Tražimo novog partnera...");
            setReportEnabled(false);
            appendTextChat("⏭️ Next...", "system");

            await chatConnection.invoke("Next");
        }

        // ===== Report =====
        function openReportModal() {
            if (!hasStarted) return;
            document.getElementById("reportModal").style.display = "flex";
        }

        function closeReportModal() {
            document.getElementById("reportModal").style.display = "none";
        }

        async function submitTextReport() {
            const reason = document.getElementById("reportReason").value;
            closeReportModal();

            if (!chatConnection || chatConnection.state !== "Connected") return;

            showLoader(true);
            setStatus("Tražimo novog partnera...");
            setReportEnabled(false);
            appendTextChat("🚩 Prijava poslata. Tražimo ti novog partnera...", "system");

            await chatConnection.invoke("ReportPartner", reason);
        }

        // Enter = send
        document.addEventListener("keydown", function (e) {
            const input = document.getElementById("textMessageInput");
            if (e.key === "Enter" && input === document.activeElement) {
                e.preventDefault();
                sendTextMessage();
            }
        });

        // Report modal: overlay click + Escape to close; otherwise Escape = Next
        document.getElementById("reportModal").addEventListener("click", e => {
            if (e.target === e.currentTarget) closeReportModal();
        });

        document.addEventListener("keydown", e => {
            if (e.key !== "Escape") return;
            const reportModal = document.getElementById("reportModal");
            if (reportModal && reportModal.style.display === "flex") { closeReportModal(); return; }
            if (hasStarted) nextTextPartner();
        });

        // Enter in interest field starts the chat
        document.getElementById("interestInput").addEventListener("keydown", e => {
            if (e.key === "Enter") { e.preventDefault(); if (!hasStarted) startTextChat(); }
        });
    </script>
}

@section Styles {
    <style>
        .text-chat-wrapper {
            background: #000;
            color: #fff;
            padding: 20px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .tc-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 14px;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.10);
        }

        .tc-status {
            font-size: 13px;
            font-weight: 800;
            color: rgba(255,255,255,.72);
        }

        .tc-ghost-btn {
            height: 36px;
            padding: 0 14px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.14);
            background: rgba(255,255,255,.06);
            color: rgba(255,255,255,.90);
            font-weight: 800;
            font-size: 12.5px;
            cursor: pointer;
            transition: transform .12s ease, filter .12s ease, border-color .12s ease, opacity .12s ease;
        }

            .tc-ghost-btn:hover:not(:disabled) {
                transform: translateY(-1px);
                filter: brightness(1.05);
                border-color: rgba(250,204,21,.25);
            }

            .tc-ghost-btn:disabled {
                opacity: .45;
                cursor: not-allowed;
            }

        .tc-chat-area {
            position: relative;
            flex: 1;
            min-height: 0;
            display: flex;
            flex-direction: column;
        }

        #textChatBox {
            flex: 1;
            min-height: 0;
            background: #0b0d11;
            border: 1px solid #1e2430;
            border-radius: 18px;
            padding: 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .tc-msg {
            max-width: 82%;
            padding: 10px 12px;
            border-radius: 16px;
            line-height: 1.4;
            word-break: break-word;
            font-size: 14.5px;
        }

            .tc-msg.partner {
                align-self: flex-start;
                background: #141823;
                border: 1px solid #232a38;
                color: rgba(255,255,255,.92);
                border-top-left-radius: 10px;
            }

            .tc-msg.me {
                align-self: flex-end;
                background: #1b1f2b;
                border: 1px solid rgba(250,204,21,.35);
                color: rgba(255,255,255,.92);
                border-top-right-radius: 10px;
            }

            .tc-msg.system {
                align-self: center;
                max-width: 92%;
                text-align: center;
                background: #111520;
                border: 1px dashed #2a3242;
                color: rgba(255,255,255,.72);
                font-weight: 800;
                font-size: 13px;
            }

        .tc-loader {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            gap: 12px;
            background: rgba(0,0,0,.55);
            border-radius: 18px;
            backdrop-filter: blur(6px);
            z-index: 5;
        }

        .tc-spinner {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 5px solid rgba(255,255,255,.18);
            border-top-color: #facc15;
            animation: tcSpin 1s linear infinite;
        }

        @@keyframes tcSpin {
            to { transform: rotate(360deg); }
        }

        .tc-loader-text {
            color: rgba(255,255,255,.86);
            font-weight: 800;
            font-size: 13.5px;
        }

        #typingStatus {
            min-height: 24px;
            color: rgba(255,255,255,.62);
            font-size: 13px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px 2px;
        }

        .typing-dots {
            display: inline-flex;
            gap: 4px;
            align-items: center;
        }

            .typing-dots span {
                width: 6px;
                height: 6px;
                border-radius: 999px;
                background: rgba(250,204,21,.8);
                opacity: .55;
                animation: tcDots 1.2s infinite ease-in-out;
            }

                .typing-dots span:nth-child(2) { animation-delay: .15s; }
                .typing-dots span:nth-child(3) { animation-delay: .3s; }

        @@keyframes tcDots {
            0%, 100% { transform: translateY(0); opacity: .45; }
            50%      { transform: translateY(-3px); opacity: .95; }
        }

        .input-row {
            display: flex;
            gap: 10px;
        }

            .input-row input[type="text"] {
                flex: 1;
                padding: 0 14px;
                height: 46px;
                border: none;
                border-radius: 14px;
                background: #1c1c1c;
                color: #fff;
                outline: none;
                font-size: 14.5px;
                transition: box-shadow .15s ease;
            }

                .input-row input[type="text"]:focus {
                    box-shadow: 0 0 0 3px rgba(250,204,21,.22);
                }

                .input-row input[type="text"]:disabled {
                    opacity: .5;
                }

        .tc-primary-btn {
            height: 46px;
            padding: 0 18px;
            background: #facc15;
            border: 1px solid rgba(250,204,21,.4);
            border-radius: 14px;
            font-weight: 800;
            color: #000;
            cursor: pointer;
            transition: transform .12s ease, filter .12s ease;
        }

            .tc-primary-btn:hover {
                transform: translateY(-1px);
                filter: brightness(1.04);
            }

            .tc-primary-btn:active {
                transform: translateY(0) scale(.98);
            }

        .tc-esc-text {
            color: rgba(255,255,255,.40);
            font-size: 12px;
            font-weight: 700;
        }

        @@media (max-width: 768px) {
            .input-row {
                flex-direction: column;
            }

                .input-row input[type="text"], .tc-primary-btn {
                    width: 100%;
                }

            .tc-topbar {
                flex-wrap: wrap;
            }
        }
    </style>
}
