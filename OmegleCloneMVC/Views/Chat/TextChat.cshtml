@{
    ViewData["Title"] = "Text Chat";
}

<div class="text-chat-wrapper">
    <div id="textChatBox"></div>

    <div id="typingStatus"></div>

    <div class="input-row">
        <input type="text" id="interestInput" placeholder="Unesi interesovanja (npr: sport, film)..." />
        <button id="startBtn" onclick="startTextChat()">Start</button>
    </div>

    <div class="input-row">
        <input type="text" id="textMessageInput" placeholder="Napiši poruku..." oninput="notifyTextTyping()" />
        <button onclick="sendTextMessage()">Send</button>
        <button onclick="nextTextPartner()">Next</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let chatConnection;
        let typingTimeout;
        let started = false;

        async function startTextChat() {
            if (started && chatConnection && chatConnection.state === "Connected") {
                appendTextChat("ℹ️ Već si povezan. Klikni Next za novog partnera.");
                return;
            }

            const interestInput = document.getElementById("interestInput");
            const startBtn = document.getElementById("startBtn");
            const interest = interestInput.value.trim();

            chatConnection = new signalR.HubConnectionBuilder()
                .withUrl("/textChatHub?interest=" + encodeURIComponent(interest))
                .withAutomaticReconnect()
                .build();

            chatConnection.on("ReceiveMessage", msg => {
                appendTextChat("Partner: " + msg);
            });

            chatConnection.on("ReceiveTyping", () => {
                document.getElementById("typingStatus").innerText = "Partner kuca...";
                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(() => {
                    document.getElementById("typingStatus").innerText = "";
                }, 1500);
            });

            chatConnection.on("PartnerDisconnected", () => {
                appendTextChat("❌ Partner je napustio chat.");
                appendTextChat("🔎 Tražimo novog partnera...");
            });

            chatConnection.onreconnected(() => {
                appendTextChat("✅ Ponovo povezano.");
            });

            chatConnection.onclose(() => {
                started = false;
                startBtn.disabled = false;
                startBtn.innerText = "Start";
                interestInput.disabled = false;
                appendTextChat("⚠️ Konekcija zatvorena. Klikni Start.");
            });

            await chatConnection.start();

            started = true;
            startBtn.disabled = true;
            startBtn.innerText = "Searching...";
            interestInput.disabled = true;

            appendTextChat("🔎 Tražimo partnera...");
        }

        function sendTextMessage() {
            const msgInput = document.getElementById("textMessageInput");
            const msg = msgInput.value.trim();
            if (!msg) return;

            if (!chatConnection || chatConnection.state !== "Connected") {
                appendTextChat("⚠️ Nisi povezan. Klikni Start.");
                return;
            }

            appendTextChat("Ti: " + msg);
            chatConnection.invoke("SendMessage", msg);
            msgInput.value = "";
            msgInput.focus();
        }

        function notifyTextTyping() {
            if (chatConnection && chatConnection.state === "Connected") {
                chatConnection.invoke("SendTyping");
            }
        }

        async function nextTextPartner() {
            if (!chatConnection || chatConnection.state !== "Connected") {
                appendTextChat("⚠️ Nisi povezan. Klikni Start.");
                return;
            }

            document.getElementById("typingStatus").innerText = "";
            document.getElementById("textMessageInput").value = "";
            appendTextChat("⏭️ Next...");
            appendTextChat("🔎 Tražimo novog partnera...");

            // KLJUČNO: ne stopiraš konekciju — samo pozoveš hub Next()
            await chatConnection.invoke("Next");
        }

        function appendTextChat(msg) {
            const box = document.getElementById("textChatBox");
            const div = document.createElement("div");
            div.textContent = msg;
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        // Enter = send
        document.addEventListener("keydown", function (e) {
            const input = document.getElementById("textMessageInput");
            if (e.key === "Enter" && input === document.activeElement) {
                e.preventDefault();
                sendTextMessage();
            }
        });
    </script>
}

@section Styles {
    <style>
        .text-chat-wrapper {
            background: #000;
            color: #fff;
            padding: 30px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        #textChatBox {
            background: #111;
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 10px;
        }

        .input-row {
            display: flex;
            gap: 10px;
        }

            .input-row input[type="text"] {
                flex: 1;
                padding: 10px;
                border: none;
                border-radius: 5px;
                background: #222;
                color: #fff;
            }

        button {
            padding: 10px 16px;
            background: #facc15;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
        }
    </style>
}
