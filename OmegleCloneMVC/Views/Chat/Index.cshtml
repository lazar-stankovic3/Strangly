@{
    ViewData["Title"] = "Strangly";
}

<div class="video-chat-root">
    <div class="vc-container">

        <div class="video-column">

            <div class="vc-topbar">
                <div class="control-group">
                    <div class="online-chip" id="onlineUsers">👥 0 online</div>

                    <div class="control-group">
                        <span class="control-label">Ja sam:</span>
                        <div class="segmented" id="genderSeg">
                            <button type="button" class="seg-btn" data-value="male">Muško</button>
                            <button type="button" class="seg-btn" data-value="female">Žensko</button>
                        </div>
                    </div>

                    <div class="control-group">
                        <span class="control-label">Tražim:</span>
                        <div class="segmented" id="genderFilterSeg">
                            <button type="button" class="seg-btn is-active" data-value="any">Bilo koji</button>
                            <button type="button" class="seg-btn" data-value="male">Muško</button>
                            <button type="button" class="seg-btn" data-value="female">Žensko</button>
                        </div>
                    </div>
                </div>

                <div class="control-group">
                    <button id="devicesBtn" type="button" class="ghost-btn">Uređaji</button>
                </div>

            </div>

            <div id="deviceDrawer" class="device-drawer">
                <div class="device-row">
                    <span class="device-title">Kamera:</span>
                    <div class="device-list" id="videoDeviceList"></div>
                </div>

                <div class="device-row">
                    <span class="device-title">Mikrofon:</span>
                    <div class="device-list" id="audioDeviceList"></div>
                </div>
            </div>

            <div class="video-stage">
                <div class="badge">Partner</div>
                <video id="remoteVideo" autoplay playsinline></video>

                <div class="pip">
                    <div class="badge">Ti</div>
                    <video id="localVideo" autoplay muted playsinline></video>
                </div>
            </div>
        </div>

        <div class="chat-column">
            <div id="loader" class="loader-container" style="display:none;">
                <div class="loader-spinner"></div>
                <div class="loader-text">Tražimo partnera...</div>
            </div>

            <div id="chatBox"></div>
            <div id="typingStatus"></div>

            <div class="input-wrapper">
                <input type="text" id="messageInput" placeholder="Write a message..." oninput="notifyTyping()" />

                <div class="input-actions">
                    <button id="startBtn" type="button" class="startnext-btn">Start</button>
                    <button class="send-btn" type="button" onclick="sendMessage()">Send</button>
                    <button id="muteBtn" type="button" class="mute-btn" onclick="toggleMic()">Mute</button>
                </div>

                <small class="esc-text">(ESC za sledećeg partnera)</small>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script src="/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script>
        const HUB_BASE    = "/chatHub";
        const PREMIUM_URL = "/Subscription/PremiumStatus";
        const MAX_MSG_LEN = 500; // must match server-side MaxMessageLength

        // ===== WebRTC/SignalR state =====
        let localStream    = null;
        let peerConnection = null;
        let connection     = null;
        let typingTimeout  = null;
        let iAmInitiator   = false;

        // manualNext: set true before invoking Next(), cleared in PartnerDisconnected handler.
        // This prevents the auto-StartMatch call that PartnerDisconnected would otherwise trigger,
        // because the server already handles finding the next partner inside Next().
        let manualNext = false;

        // one button (Start -> Next)
        let hasStarted = false;

        // premium UI flag
        let isPremiumUser = false;

        // Client-side Next() debounce (server also rate-limits, but this avoids unnecessary calls)
        let lastNextMs = 0;
        const NEXT_DEBOUNCE_MS = 1500;

        // ===== UI state (segmented/chips) =====
        let selectedGender = "";
        let selectedGenderFilter = "any";
        let selectedVideoDeviceId = "";
        let selectedAudioDeviceId = "";

        const rtcConfig = {
            iceServers: [{ urls: ["stun:stun.l.google.com:19302"] }]
        };

        // ===== Helpers =====
        function showLoader(show) {
            const el = document.getElementById("loader");
            if (el) el.style.display = show ? "flex" : "none";
        }

        function setMainButton(state) {
            const btn = document.getElementById("startBtn");
            if (!btn) return;

            if (!state) {
                btn.textContent = "Start";
                hasStarted = false;
            } else {
                btn.textContent = "Next";
                hasStarted = true;
            }
        }

        function appendChat(text, type = "system") {
            const box = document.getElementById("chatBox");
            if (!box) return;

            const wrap = document.createElement("div");
            wrap.className = `msg ${type}`;

            const body = document.createElement("div");
            body.className = "body";
            body.textContent = text;

            const meta = document.createElement("div");
            meta.className = "meta";

            const time = new Date();
            const hh = String(time.getHours()).padStart(2, "0");
            const mm = String(time.getMinutes()).padStart(2, "0");

            const who =
                type === "me" ? "Ti" :
                type === "partner" ? "Partner" :
                "Info";

            meta.textContent = `${who} • ${hh}:${mm}`;

            wrap.appendChild(body);
            wrap.appendChild(meta);
            box.appendChild(wrap);

            box.scrollTop = box.scrollHeight;
        }

        async function safeInvoke(method, ...args) {
            if (!connection) return;
            if (connection.state !== signalR.HubConnectionState.Connected) return;
            try { await connection.invoke(method, ...args); }
            catch (e) { console.warn("invoke failed", method, e); }
        }

        function getInterestFromUrl() {
            const p = new URLSearchParams(window.location.search);
            return p.get("interest") || "";
        }

        // ===== Segmented =====
        function setupSegmented(segId, initialValue, onChange) {
            const seg = document.getElementById(segId);
            if (!seg) return;

            const buttons = [...seg.querySelectorAll(".seg-btn")];

            function setActive(val) {
                buttons.forEach(b => b.classList.toggle("is-active", b.dataset.value === val));
            }

            if (initialValue) setActive(initialValue);

            buttons.forEach(b => {
                b.addEventListener("click", () => {
                    if (b.disabled) {
                        appendChat("🔒 Premium: filter po polu je dostupan samo premium korisnicima.", "system");
                        return;
                    }
                    const val = b.dataset.value;
                    setActive(val);
                    onChange(val);
                });
            });
        }

        // ===== Premium lock (Tražim) =====
        function setGenderFilterLocked(locked) {
            const seg = document.getElementById("genderFilterSeg");
            if (!seg) return;

            const btns = [...seg.querySelectorAll(".seg-btn")];

            btns.forEach(b => {
                const val = b.dataset.value;

                if (val === "any") {
                    b.disabled = false;
                    b.classList.remove("is-locked");
                    b.title = "";
                    return;
                }

                b.disabled = locked;
                b.classList.toggle("is-locked", locked);
                b.title = locked ? "Premium feature 🔒" : "";
            });

            if (locked) {
                selectedGenderFilter = "any";
                btns.forEach(b => b.classList.toggle("is-active", b.dataset.value === "any"));
            }
        }

        async function applyPremiumUi() {
            try {
                const r = await fetch(PREMIUM_URL, { credentials: "same-origin" });
                if (!r.ok) {
                    isPremiumUser = false;
                    setGenderFilterLocked(true);
                    return;
                }

                const j = await r.json();
                isPremiumUser = !!j.isPremium;

                setGenderFilterLocked(!isPremiumUser);

            } catch {
                isPremiumUser = false;
                setGenderFilterLocked(true);
            }
        }

        // ===== Devices (chips) =====
        function renderDeviceChips(containerId, devices, selectedId, onPick) {
            const wrap = document.getElementById(containerId);
            if (!wrap) return;

            wrap.innerHTML = "";

            if (!devices.length) {
                const b = document.createElement("button");
                b.type = "button";
                b.className = "device-chip";
                b.textContent = "Nema uređaja";
                b.disabled = true;
                wrap.appendChild(b);
                return;
            }

            devices.forEach((d, idx) => {
                const b = document.createElement("button");
                b.type = "button";
                b.className = "device-chip" + (d.deviceId === selectedId ? " is-active" : "");
                b.textContent = d.label || ((d.kind === "videoinput" ? "Kamera " : "Mik ") + (idx + 1));
                b.onclick = () => onPick(d.deviceId);
                wrap.appendChild(b);
            });
        }

        async function populateDeviceChips() {
            try {
                const devices = await navigator.mediaDevices.enumerateDevices();
                const cams = devices.filter(d => d.kind === "videoinput");
                const mics = devices.filter(d => d.kind === "audioinput");

                if (!selectedVideoDeviceId && cams[0]) selectedVideoDeviceId = cams[0].deviceId;
                if (!selectedAudioDeviceId && mics[0]) selectedAudioDeviceId = mics[0].deviceId;

                renderDeviceChips("videoDeviceList", cams, selectedVideoDeviceId, async (id) => {
                    selectedVideoDeviceId = id;
                    await populateDeviceChips();
                    await switchDevicesLive();
                });

                renderDeviceChips("audioDeviceList", mics, selectedAudioDeviceId, async (id) => {
                    selectedAudioDeviceId = id;
                    await populateDeviceChips();
                    await switchDevicesLive();
                });
            } catch (e) {
                console.warn("Cannot enumerate devices:", e);
            }
        }

        async function requestMediaPermissionsAndListDevices() {
            try {
                const tmp = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
                tmp.getTracks().forEach(t => t.stop());
            } catch (e) {
                console.warn("Permission blocked/failed:", e);
            }
            await populateDeviceChips();
        }

        // ===== Media =====
        async function getMediaStream() {
            const constraints = {
                video: selectedVideoDeviceId ? { deviceId: { exact: selectedVideoDeviceId } } : true,
                audio: selectedAudioDeviceId ? { deviceId: { exact: selectedAudioDeviceId } } : true
            };
            return await navigator.mediaDevices.getUserMedia(constraints);
        }

        function attachLocalStream() {
            const lv = document.getElementById("localVideo");
            if (lv) lv.srcObject = localStream;
        }

        async function ensureLocalStream() {
            if (localStream) return true;
            try {
                localStream = await getMediaStream();
                attachLocalStream();
                return true;
            } catch (e) {
                appendChat("❌ Kamera/mikrofon nisu dostupni: " + (e?.message || e), "system");
                return false;
            }
        }

        async function createPeerConnectionIfNeeded() {
            if (peerConnection) return;

            peerConnection = new RTCPeerConnection(rtcConfig);

            peerConnection.ontrack = e => {
                const rv = document.getElementById("remoteVideo");
                if (!rv) return;
                rv.srcObject = e.streams[0];
                rv.play?.().catch(() => { });
            };

            peerConnection.onicecandidate = e => {
                if (e.candidate) safeInvoke("SendIceCandidate", e.candidate);
            };

            if (localStream) {
                localStream.getTracks().forEach(t => peerConnection.addTrack(t, localStream));
            }
        }

        function cleanupWebRtc() {
            if (peerConnection) {
                try { peerConnection.close(); } catch { }
                peerConnection = null;
            }
            const rv = document.getElementById("remoteVideo");
            if (rv) rv.srcObject = null;
        }

        async function switchDevicesLive() {
            if (!localStream) return;

            try {
                const newStream = await getMediaStream();
                const newVideoTrack = newStream.getVideoTracks()[0] || null;
                const newAudioTrack = newStream.getAudioTracks()[0] || null;

                const oldVideoTrack = localStream.getVideoTracks()[0] || null;
                const oldAudioTrack = localStream.getAudioTracks()[0] || null;

                if (peerConnection) {
                    if (newVideoTrack) {
                        const vs = peerConnection.getSenders().find(s => s.track && s.track.kind === "video");
                        if (vs) await vs.replaceTrack(newVideoTrack);
                    }
                    if (newAudioTrack) {
                        const as = peerConnection.getSenders().find(s => s.track && s.track.kind === "audio");
                        if (as) await as.replaceTrack(newAudioTrack);
                    }
                }

                oldVideoTrack?.stop();
                oldAudioTrack?.stop();

                localStream = new MediaStream(
                    []
                        .concat(newVideoTrack ? [newVideoTrack] : [])
                        .concat(newAudioTrack ? [newAudioTrack] : [])
                );

                attachLocalStream();
            } catch (e) {
                console.warn("Switch devices failed:", e);
                appendChat("⚠️ Ne mogu da promenim uređaj: " + (e?.message || e), "system");
            }
        }

        // ===== SignalR =====
        async function setupSignalR(gender, genderFilter) {
            const interest = getInterestFromUrl();

            connection = new signalR.HubConnectionBuilder()
                .withUrl(HUB_BASE + "?gender=" + encodeURIComponent(gender)
                    + "&genderFilter=" + encodeURIComponent(genderFilter)
                    + "&interest=" + encodeURIComponent(interest))
                .withAutomaticReconnect([0, 1000, 2000, 5000])
                .configureLogging(signalR.LogLevel.Information)
                .build();

            connection.on("Searching", () => showLoader(true));

            connection.on("UpdateOnlineUsers", count => {
                const el = document.getElementById("onlineUsers");
                if (el) el.textContent = "👥 " + count + " online";
            });

            connection.on("MatchFound", async payload => {
                iAmInitiator = !!payload.initiator;
                showLoader(false);

                appendChat("✅ Partner povezan.", "system");
                if (payload.partnerGender) appendChat("Partner: " + payload.partnerGender, "system");
                if (payload.commonInterest) appendChat("💡 Zajedničko interesovanje: " + payload.commonInterest, "system");

                setMainButton(true);

                const ok = await ensureLocalStream();
                if (!ok) return;

                await createPeerConnectionIfNeeded();

                if (iAmInitiator) {
                    const offer = await peerConnection.createOffer();
                    await peerConnection.setLocalDescription(offer);
                    await safeInvoke("SendOffer", offer);
                }
            });

            connection.on("ReceiveOffer", async offer => {
                const ok = await ensureLocalStream();
                if (!ok) return;

                await createPeerConnectionIfNeeded();
                await peerConnection.setRemoteDescription(new RTCSessionDescription(offer));

                const answer = await peerConnection.createAnswer();
                await peerConnection.setLocalDescription(answer);
                await safeInvoke("SendAnswer", answer);
            });

            connection.on("ReceiveAnswer", async answer => {
                if (!peerConnection) return;
                await peerConnection.setRemoteDescription(new RTCSessionDescription(answer));
                showLoader(false);
            });

            connection.on("ReceiveIceCandidate", async cand => {
                if (!peerConnection) return;
                try { await peerConnection.addIceCandidate(new RTCIceCandidate(cand)); }
                catch (e) { console.warn("addIceCandidate failed", e); }
            });

            connection.on("ReceiveMessage", msg => appendChat(msg, "partner"));

            connection.on("ReceiveTyping", () => {
                const ts = document.getElementById("typingStatus");
                if (!ts) return;

                ts.innerHTML = `Partner kuca <span class="typing-dots"><span></span><span></span><span></span></span>`;
                clearTimeout(typingTimeout);
                typingTimeout = setTimeout(() => ts.innerHTML = "", 1500);
            });

            connection.on("PartnerDisconnected", async () => {
                // Consume the manualNext flag atomically here (before any async gap).
                // If Next() was the trigger, manualNext=true → server already handles rematch.
                // If partner disconnected naturally, manualNext=false → we call StartMatch.
                const wasManual = manualNext;
                manualNext = false;

                appendChat("❌ Partner je napustio razgovor.", "system");
                cleanupWebRtc();
                showLoader(true);

                // Clear typing indicator immediately
                const ts = document.getElementById("typingStatus");
                if (ts) ts.innerHTML = "";
                clearTimeout(typingTimeout);

                setMainButton(true);

                if (!wasManual) {
                    setTimeout(() => safeInvoke("StartMatch"), 200);
                }
            });

            connection.onclose(() => setMainButton(false));

            connection.onreconnected(() => {
                appendChat("✅ Ponovo povezano.", "system");
                safeInvoke("StartMatch");
            });

            try {
                await connection.start();
            } catch (e) {
                console.error("SignalR start failed:", e);
                appendChat("❌ Connection failed. Please refresh the page.", "system");
                showLoader(false);
                setMainButton(false);
                return;
            }

            await safeInvoke("StartMatch");
        }

        // ===== Start / Next =====
        async function start() {
            if (typeof window.signalR === "undefined") {
                alert("SignalR nije učitan. Proveri script path.");
                return;
            }

            const gender = selectedGender;
            const genderFilter = selectedGenderFilter;

            showLoader(true);

            if (!connection || connection.state !== signalR.HubConnectionState.Connected) {
                await setupSignalR(gender, genderFilter);
            } else {
                await safeInvoke("StartMatch");
            }
        }

        async function next() {
            // Client-side debounce (server enforces 1.5s too, but this avoids wasted round-trips)
            const now = Date.now();
            if (now - lastNextMs < NEXT_DEBOUNCE_MS) return;
            lastNextMs = now;

            // Set BEFORE the invoke. The PartnerDisconnected handler (which fires during/after
            // the invoke) reads this flag and skips the auto-StartMatch because the server's
            // Next() already handles finding a new match.
            manualNext = true;

            cleanupWebRtc();

            const box = document.getElementById("chatBox");
            if (box) box.innerHTML = "";

            const ts = document.getElementById("typingStatus");
            if (ts) ts.innerHTML = "";
            clearTimeout(typingTimeout);

            showLoader(true);

            await safeInvoke("Next");
            // Do NOT reset manualNext here — it is reset inside the PartnerDisconnected handler.
        }

        async function startOrNext() {
            if (!hasStarted) {
                await start();
                setMainButton(true);
                return;
            }
            await next();
        }

        // ===== Chat =====
        async function sendMessage() {
            const input = document.getElementById("messageInput");
            let msg = (input?.value || "").trim();
            if (!msg) return;

            // Enforce max length client-side (server also enforces this)
            if (msg.length > MAX_MSG_LEN) msg = msg.slice(0, MAX_MSG_LEN);

            appendChat(msg, "me");
            await safeInvoke("SendMessage", msg);

            input.value = "";
        }

        let lastTypingSent = 0;

        function notifyTyping() {
            const now = Date.now();
            if (now - lastTypingSent < 400) return; // max ~2-3 puta u sekundi
            lastTypingSent = now;
            safeInvoke("SendTyping");
        }


        function toggleMic() {
            if (!localStream) return;

            const tracks = localStream.getAudioTracks();
            if (!tracks.length) return;

            const nowEnabled = !tracks[0].enabled;
            tracks.forEach(t => t.enabled = nowEnabled);

            const btn = document.getElementById("muteBtn");
            if (btn) btn.textContent = nowEnabled ? "Mute" : "Unmute";
        }

        // ===== Init =====
        window.addEventListener("load", async () => {
            setupSegmented("genderSeg", "", (val) => selectedGender = val);
            setupSegmented("genderFilterSeg", "any", (val) => selectedGenderFilter = val);

            // device drawer toggle
            const devicesBtn = document.getElementById("devicesBtn");
            if (devicesBtn) {
                devicesBtn.addEventListener("click", () => {
                    document.getElementById("deviceDrawer")?.classList.toggle("is-open");
                });
            }

            await applyPremiumUi();

            // permissions + chips
            await requestMediaPermissionsAndListDevices();

            if (navigator.mediaDevices?.addEventListener) {
                navigator.mediaDevices.addEventListener("devicechange", async () => {
                    await populateDeviceChips();
                });
            }

            // start/next
            document.getElementById("startBtn").addEventListener("click", startOrNext);

            // ESC = Next (only if started)
            document.addEventListener("keydown", e => {
                if (e.key === "Escape" && hasStarted) next();
            });

            // Enter send
            document.getElementById("messageInput").addEventListener("keydown", e => {
                if (e.key === "Enter") { e.preventDefault(); sendMessage(); }
            });

            setMainButton(false);
        });
    </script>
}
