@{
    ViewData["Title"] = "Welcome";
    ViewData["BodyClass"] = "home-page";
}
<div class="home-hero">
    <div class="hero-bg" aria-hidden="true">
        <span class="hero-blob hero-blob--a"></span>
        <span class="hero-blob hero-blob--b"></span>
    </div>

    <div class="hero-wrap">
        <div class="hero-eyebrow hero-animate">
            <span class="online-dot-pulse"></span>
            <span id="heroOnlineCount">—</span>&nbsp;people chatting right now
        </div>

        <h1 class="hero-title hero-animate">
            <span class="hero-title-light">Meet strangers,</span><br />
            <span class="hero-accent">instantly.</span>
        </h1>

        <p class="subtitle hero-animate">
            Anonymous video &amp; text chat with people worldwide. No account, no signup — just talk.
        </p>

        <div class="hero-action hero-animate">
            <div class="hero-input-wrap">
                <span class="hero-input-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                </span>
                <input id="interestInput" type="text" placeholder="What do you want to talk about? (optional)" autocomplete="off" />
            </div>

            <div class="hero-buttons">
                <button class="chat-btn chat-btn--text" onclick="startTextChat()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                    Text
                </button>
                <button class="chat-btn chat-btn--video" onclick="startVideoChat()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7" /><rect x="1" y="5" width="15" height="14" rx="2" ry="2" /></svg>
                    Video
                </button>
            </div>
        </div>

        <p class="hero-tagline hero-animate">Anonymous &middot; Instant matching &middot; Free, no account needed</p>

        <div class="hero-stats hero-animate">
            <div class="hero-stat">
                <span class="hero-stat-num">2M+</span>
                <span class="hero-stat-label">Users worldwide</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">50K+</span>
                <span class="hero-stat-label">Chats today</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">190+</span>
                <span class="hero-stat-label">Countries</span>
            </div>
        </div>
    </div>
</div>

<footer class="home-footer">
    <div class="footer-links">
        <a href="/about">About</a>
        <a href="/rules">Rules</a>
        <a href="/Home/Privacy">Privacy</a>
        <a href="/support">Support</a>
    </div>
    <div class="footer-copy">© 2026 Strangly</div>
</footer>

<div id="agreementModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
        </div>
        <h2>Before you continue</h2>
        <p>
            Please confirm you've read and agree to our
            <a href="/rules" target="_blank">Community Rules</a> and
            <a href="/Home/Privacy" target="_blank">Privacy Policy</a>.
        </p>
        <label class="checkbox-label">
            <input type="checkbox" id="agreementCheckbox" />
            I agree to the terms and I am 18+ years old.
        </label>
        <div class="modal-buttons">
            <button onclick="proceedToChat()">Continue</button>
            <button class="modal-cancel-btn" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>


@section Scripts {
    <script src="/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        // live online counter (read-only SignalR connection)
        (() => {
            const conn = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .configureLogging(signalR.LogLevel.None)
                .build();
            conn.on("UpdateOnlineUsers", n => {
                const el = document.getElementById("heroOnlineCount");
                if (!el) return;
                const newText = n.toLocaleString();
                if (el.textContent === newText) return;
                el.textContent = newText;
                el.classList.remove("bump");
                void el.offsetWidth; // restart animation
                el.classList.add("bump");
            });
            conn.start().catch(() => {});
        })();
    </script>
    <script>
        // Smooth count-up animation for the stats row (2M+, 50K+, 190+...)
        (() => {
            const reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            const nums = document.querySelectorAll(".hero-stat-num");

            nums.forEach((el, i) => {
                const raw = el.textContent.trim();
                const match = raw.match(/^(\d+(?:\.\d+)?)(.*)$/);
                if (!match) return;

                const end = parseFloat(match[1]);
                const suffix = match[2];
                const isInt = Number.isInteger(end);

                if (reduceMotion) return; // keep final value, skip animation

                el.textContent = (isInt ? 0 : (0).toFixed(1)) + suffix;

                const duration = 1100;
                const startDelay = 480 + i * 110;

                setTimeout(() => {
                    const startTime = performance.now();
                    function tick(now) {
                        const p = Math.min(1, (now - startTime) / duration);
                        const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
                        const value = end * eased;
                        el.textContent = (isInt ? Math.round(value) : value.toFixed(1)) + suffix;
                        if (p < 1) requestAnimationFrame(tick);
                    }
                    requestAnimationFrame(tick);
                }, startDelay);
            });
        })();
    </script>
    <script>
        let redirectUrl = "";
        const AGREEMENT_KEY = "strangly.agreedToRules.v1";

        function hasAgreedAlready() {
            try { return localStorage.getItem(AGREEMENT_KEY) === "1"; }
            catch { return false; }
        }

        function rememberAgreement() {
            try { localStorage.setItem(AGREEMENT_KEY, "1"); } catch { }
        }

        function startTextChat() {
            const interest = document.getElementById("interestInput").value;
            redirectUrl = `/Chat/Text${interest ? `?interest=${encodeURIComponent(interest)}` : ''}`;
            if (hasAgreedAlready()) { window.location.href = redirectUrl; return; }
            openModal();
        }

        function startVideoChat() {
            const interest = document.getElementById("interestInput").value;
            redirectUrl = `/Chat/Video${interest ? `?interest=${encodeURIComponent(interest)}` : ''}`;
            if (hasAgreedAlready()) { window.location.href = redirectUrl; return; }
            openModal();
        }

        function openModal() {
            document.getElementById("agreementCheckbox").checked = false;
            document.getElementById("agreementModal").style.display = "flex";
        }

        function closeModal() {
            document.getElementById("agreementModal").style.display = "none";
        }

        function proceedToChat() {
            const checkbox = document.getElementById("agreementCheckbox");
            if (!checkbox.checked) {
                checkbox.closest('.checkbox-label').classList.add('shake');
                setTimeout(() => checkbox.closest('.checkbox-label').classList.remove('shake'), 500);
                return;
            }
            rememberAgreement();
            window.location.href = redirectUrl;
        }

        // Press Enter in interest field → start text chat
        document.getElementById("interestInput").addEventListener("keydown", (e) => {
            if (e.key === "Enter") startTextChat();
        });

        // Close modal on overlay click
        document.getElementById("agreementModal").addEventListener("click", function(e) {
            if (e.target === this) closeModal();
        });

        // Close modal on Escape
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeModal();
        });
    </script>
}
