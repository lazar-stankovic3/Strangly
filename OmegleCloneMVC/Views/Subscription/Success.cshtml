@{
    ViewData["Title"] = "Success";
}

<div style="max-width:560px;margin:40px auto;padding:20px;border-radius:18px;background:rgba(18,18,18,.75);border:1px solid rgba(255,255,255,.10);color:white;">
    <h2 style="margin:0 0 10px;">✅ Payment successful</h2>
    <p style="color:rgba(255,255,255,.75);margin:0 0 14px;">
        Aktiviramo Premium... može potrajati par sekundi (webhook).
    </p>

    <form id="refreshForm" method="post" action="/Subscription/RefreshPremium">
        @Html.AntiForgeryToken()
        <button id="activateBtn" type="submit" style="padding:10px 14px;border-radius:12px;border:none;background:#facc15;font-weight:950;cursor:pointer;">
            Activate Premium
        </button>
    </form>

    <p id="status" style="margin-top:12px;color:rgba(255,255,255,.75)"></p>
</div>

<script>
    (async function poll(){
      try{
        const r = await fetch('/Subscription/PremiumStatus');
        if(!r.ok) return;

        const j = await r.json();
        if(j.isPremium){
          document.getElementById('status').innerText = "Premium je aktiviran ✅";
          // refresh cookie claims (da UI i server odmah prepoznaju)
          document.getElementById('activateBtn').click();
          return;
        } else {
          document.getElementById('status').innerText = "Još uvek obrađujemo... pokušavam ponovo.";
        }
      }catch{}
      setTimeout(poll, 2000);
    })();
</script>
